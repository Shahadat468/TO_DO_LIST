{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(index|register|login|logout|dashboard|add_task|edit_task|delete_task|toggle_task|delete_account)\\.php$",
      "dest": "/api/$1.php"
    },
    {
      "handle": "filesystem"
    }
  ]
}
